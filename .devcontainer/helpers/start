#!/bin/bash
# 1. Cleanup
sudo pkill -9 -f qemu-system-x86_64 2>/dev/null
sudo pkill -9 -f websockify 2>/dev/null
sudo sync && echo 3 | sudo tee /proc/sys/vm/drop_caches > /dev/null

# 2. SMART RAM CALCULATION (Automatic Preference)
# This gets total RAM in GB and subtracts 4GB for the Linux System
TOTAL_RAM_GB=$(free -g | awk '/^Mem:/{print $2}')
VM_RAM=$((TOTAL_RAM_GB - 4))

# Safety check: If machine is too small, default to 2GB
if [ "$VM_RAM" -lt 2 ]; then VM_RAM=2; fi

echo "[SYSTEM] Machine total RAM: ${TOTAL_RAM_GB}GB"
echo "[SYSTEM] Allocating ${VM_RAM}GB to Windows VM..."

# 3. Start noVNC
sudo cp /usr/share/novnc/vnc.html /usr/share/novnc/index.html 2>/dev/null
sudo /usr/bin/websockify --web /usr/share/novnc/ 8006 localhost:5900 >/dev/null 2>&1 &

# 4. BOOT WINDOWS
sudo qemu-system-x86_64 \
  -m ${VM_RAM}G \
  -smp $(nproc) \
  -enable-kvm \
  -cpu host,hv_relaxed,hv_spinlocks=0x1fff,hv_vapic,hv_time \
  -drive if=pflash,format=raw,readonly=on,file=/usr/share/OVMF/OVMF_CODE_4M.fd \
  -drive file=/tmp/windows/data.vhdx,format=vhdx,cache=writeback,aio=threads \
  -netdev user,id=net0,hostfwd=tcp::8443-:443,hostfwd=tcp::8006-:8006 \
  -device e1000,netdev=net0 \
  -vnc :0 \
  -vga std \
  -device usb-ehci,id=usb,bus=pci.0,addr=0x7 \
  -device usb-tablet \
  -audiodev none,id=none
